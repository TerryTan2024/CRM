{
    "fields": {
        "inquiryDate": {
            "type": "date",
            "audited": true
        },
        "sourceCountry": {
            "type": "varchar",
            "maxLength": 100,
            "audited": true
        },
        "sourceChannel": {
            "type": "enum",
            "options": ["", "Email", "Form", "WhatsApp", "Customer Service", "Other"],
            "audited": true,
            "displayAsLabel": true
        },
        "customerType": {
            "type": "enum",
            "options": ["", "New Inquiry", "Potential Customer", "Existing Customer", "Partner", "After-Sales", "Supplier", "Other"],
            "audited": true,
            "displayAsLabel": true
        },
        "inquiryValue": {
            "type": "enum",
            "options": ["", "High", "Medium", "Low", "None"],
            "audited": true,
            "displayAsLabel": true,
            "style": {
                "High": "success",
                "Medium": "warning",
                "Low": "info",
                "None": "default"
            }
        },
        "salesStage": {
            "type": "enum",
            "options": ["", "L0 Lost", "L1 New Inquiry", "L2 Contacted", "L3 Requirement Confirmed", "L4 Proposal Quotation", "L5 Won", "L6 No Reply"],
            "audited": true,
            "displayAsLabel": true,
            "style": {
                "L0 Lost": "danger",
                "L1 New Inquiry": "info",
                "L2 Contacted": "primary",
                "L3 Requirement Confirmed": "primary",
                "L4 Proposal Quotation": "warning",
                "L5 Won": "success",
                "L6 No Reply": "default"
            }
        },
        "demandStage": {
            "type": "enum",
            "options": ["", "Initial Contact", "Requirement Clarification", "Solution Matching", "Quotation", "Negotiation", "Won", "Lost", "On Hold"],
            "audited": true,
            "displayAsLabel": true
        },
        "nextAction": {
            "type": "enum",
            "options": ["", "Confirm Requirement", "Send Product Info", "Prepare Quotation", "Schedule Meeting", "Assign Specialist", "Follow Up", "Escalate Service", "No Action"],
            "audited": true,
            "displayAsLabel": true
        },
        "aiReplySuggestion": {
            "type": "text",
            "audited": true,
            "preview": true,
            "cutHeight": 280
        },
        "knowledgeBaseEvidence": {
            "type": "text",
            "preview": true,
            "cutHeight": 220
        },
        "replyApprovalStatus": {
            "type": "enum",
            "options": ["Draft", "Needs Review", "Approved", "Sent", "Rejected"],
            "default": "Draft",
            "audited": true,
            "displayAsLabel": true,
            "style": {
                "Draft": "info",
                "Needs Review": "warning",
                "Approved": "success",
                "Sent": "success",
                "Rejected": "danger"
            }
        },
        "sourceEmailId": {
            "type": "varchar",
            "maxLength": 36,
            "readOnly": true
        },
        "sourceEmailFrom": {
            "type": "varchar",
            "readOnly": true
        },
        "aiProcessedAt": {
            "type": "datetime",
            "readOnly": true
        }
    }
}
